#!/usr/bin/env node
"use strict";

const childProcess = require("child_process");
const path = require("path");

const root = path.resolve(__dirname, "..");
const python = process.env.PYTHON || process.env.PYTHON3 || (process.platform === "win32" ? "python" : "python3");
const env = { ...process.env };
env.PYTHONPATH = root + (env.PYTHONPATH ? path.delimiter + env.PYTHONPATH : "");

const preflight = childProcess.spawnSync(
  python,
  ["-c", "import sys; sys.exit(0 if sys.version_info >= (3, 10) else 1)"],
  { stdio: "ignore" }
);
if (preflight.error || preflight.status !== 0) {
  const reason = preflight.error
    ? `could not be launched (${preflight.error.message})`
    : "is older than Python 3.10";
  console.error(`chatbridge: Python interpreter "${python}" ${reason}.`);
  console.error("chatbridge: ChatBridge needs Python 3.10+. Set PYTHON (or PYTHON3) to a newer interpreter, e.g. PYTHON=/usr/local/bin/python3.12 chatbridge");
  process.exit(1);
}

const bootstrap = [
  "import runpy",
  "import sys",
  "sys.path.insert(0, sys.argv.pop(1))",
  "runpy.run_module('chatbridge', run_name='__main__', alter_sys=True)",
].join("; ");

const child = childProcess.spawn(python, ["-c", bootstrap, root, ...process.argv.slice(2)], {
  env,
  stdio: "inherit",
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code ?? 1);
});

child.on("error", (error) => {
  console.error(`chatbridge launcher error: ${error.message}`);
  process.exit(1);
});
